PORT=3000

# MongoDB Credentials
MONGODB_USER=your_mongodb_user
MONGODB_PASS_ENC=your_base64_encoded_mongodb_password
MONGODB_HOST=your_mongodb_host_e.g._cluster0.xxxx.mongodb.net
MONGODB_DB=careershield_ai

# JWT Secret Key (Use a strong random string in production)
# You can generate one using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here

# Environment Settings
NODE_ENV=development

# Frontend URL(s) for CORS (comma-separated for multiple origins)
# For production, set to your Vercel deployment URL (e.g., https://your-app.vercel.app)
FRONTEND_URL=http://localhost:5173

# Optional: Google OAuth
# GOOGLE_CLIENT_ID=your_google_client_id_here

# Email Configuration for OTP (Use a Gmail App Password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
